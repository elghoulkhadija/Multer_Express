<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Liste des Stagiaires</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-teal-50 min-h-screen p-8 font-sans">

    <div class="max-w-6xl mx-auto">

        <!-- En-tête -->
        <%- include ('layout/header') %>
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-semibold text-teal-800">Liste des Stagiaires</h1>
                <p class="text-sm text-teal-500 mt-1">Gestion et suivi des stagiaires enregistrés</p>
            </div>
                <a href="/api/ajouter"
                    class="inline-flex items-center gap-2 bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-medium px-5 py-2.5 rounded-xl transition-colors">
                    + Ajouter un stagiaire
                </a>
        </div>

        <!-- Tableau -->
        <div class="bg-white rounded-2xl border border-teal-100 overflow-hidden shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-teal-600 text-white">
                            <th class="px-5 py-4 text-left font-medium">Numéro</th>
                            <th class="px-5 py-4 text-left font-medium">Nom</th>
                            <th class="px-5 py-4 text-left font-medium">Prénom</th>
                            <th class="px-5 py-4 text-left font-medium">Âge</th>
                            <th class="px-5 py-4 text-left font-medium">E-mail</th>
                            <th class="px-5 py-4 text-left font-medium">Image</th>
                            <th class="px-5 py-4 text-center font-medium">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-teal-100">
                        <% stagiaires.forEach(stg =>{ %>
                        <tr class="hover:bg-lime-50 transition-colors">

                            <td class="px-5 py-3.5">
                                <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-teal-100 text-teal-700 font-semibold text-xs">
                                    <%= stg.numero %>
                                </span>
                            </td>

                            <td class="px-5 py-3.5 font-medium text-teal-900">
                                <%= stg.nom %>
                            </td>

                            <td class="px-5 py-3.5 text-teal-700">
                                <%= stg.prenom %>
                            </td>

                            <td class="px-5 py-3.5">
                                <span class="inline-block px-2.5 py-0.5 rounded-full text-xs font-medium bg-lime-100 text-lime-700 border border-lime-200">
                                    <%= stg.age %> ans
                                </span>
                            </td>

                            <td class="px-5 py-3.5 text-teal-600">
                                <%= stg.email %>
                            </td>

                            <td class="px-5 py-3.5">
                                <img src="/images/<%= stg.image %>" alt="Image"
                                    class="w-10 h-10 rounded-full object-cover border-2 border-emerald-200" />
                            </td>

                            <td class="px-5 py-3.5">
                                <div class="flex items-center justify-center gap-2">
                                     <!-- <form action="" method="" style="display: inline; "> -->
                                        <a href="/api/modifier/<%= stg._id %>" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-teal-50 border border-teal-200 text-teal-700 text-xs font-medium hover:bg-teal-100 hover:border-teal-300 transition-colors"><i class="fas fa-edit">Modifier</i></a>
                                    <!-- </form> -->
                                    <form action="/api/delete/<%= stg._id %>?_method=DELETE" method="post" style="display: inline;">
                                        <button type="submit" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-red-50 border border-red-200 text-red-600 text-xs font-medium hover:bg-red-100 hover:border-red-300 transition-colors">
                                            <i class="fas fa-trash">Supprimer</i>
                                        </button>
                                    </form>
                                </div>
                            </td>

                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>

            <!-- Pied -->
            <div class="px-6 py-3 bg-teal-50 border-t border-teal-100">
                <p class="text-xs text-teal-500">
                    Total : <span class="font-semibold text-teal-700"><%= stagiaires.length %></span> stagiaire(s)
                </p>
            </div>
        </div>
       <%- include ('layout/footer') %>
    </div>

</body>
</html>