<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modifier un Stagiaire</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-amber-0 min-h-screen flex items-center justify-center p-8 font-sans">

    <div class="w-full max-w-lg bg-white rounded-2xl border border-amber-50 shadow-sm overflow-hidden">

        <!-- En-tête -->
        <div class="bg-amber-100 px-7 py-5">
            <h2 class="text-lg font-bold text-dark-900">Modifier le Stagiaire</h2>
            <p class="text-sm text-dark-900 semi-bold mt-0.5">Mettez à jour les informations de la fiche.</p>
        </div>
<!-- change tous le texte en noir -->
        <!-- Formulaire -->
        <form action="/api/edit/<%= stagiaire._id%>?_method=PUT" method="POST" class="p-7 space-y-4" enctype="multipart/form-data">

            <!-- Numéro / Âge -->
            <div class="grid grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-dark-900 uppercase tracking-wide">
                        Numéro 
                    </label>
                    <input type="text" name="numero" value="<%= stagiaire.numero %>"
                        class="px-3 py-2.5 rounded-xl border border-amber-200 bg-amber-50 text-sm text-dark-900 focus:outline-none focus:border-amber-100 focus:ring-2 focus:ring-amber-100 transition-all" />
                </div>
                 <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-dark-900 uppercase tracking-wide">
                        Nom
                    </label>
                    <input type="text" name="nom" value="<%= stagiaire.nom %>"
                        class="px-3 py-2.5 rounded-xl border border-amber-200 bg-amber-50 text-sm text-dark-900 focus:outline-none focus:border-amber-100 focus:ring-2 focus:ring-amber-200 transition-all" />
                </div>
                
            </div>

            <!-- Nom / Prénom -->
            <div class="grid grid-cols-2 gap-4">
               
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-dark-900 uppercase tracking-wide">
                        Prénom 
                    </label>
                    <input type="text" name="prenom" value="<%= stagiaire.prenom %>"
                        class="px-3 py-2.5 rounded-xl border border-amber-200 bg-amber-50 text-sm text-dark-900 focus:outline-none focus:border-amber-100 focus:ring-2 focus:ring-amber-200 transition-all" />
                </div>
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-dark-900 uppercase tracking-wide">
                        Âge <span class="text-red-400">*</span>
                    </label>
                    <input type="number" name="age" value="<%= stagiaire.age %>" min="1" max="120"
                        class="px-3 py-2.5 rounded-xl border border-amber-200 bg-amber-50 text-sm text-dark-900 focus:outline-none focus:border-amber-100 focus:ring-2 focus:ring-amber-200 transition-all" />
                </div>
            </div>

            <!-- Email -->
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-semibold text-dark-900 uppercase tracking-wide">
                    Adresse e-mail 
                </label>
                <input type="email" name="email" value="<%= stagiaire.email %>"
                    class="px-3 py-2.5 rounded-xl border border-amber-200 bg-amber-50 text-sm text-dark-900 focus:outline-none focus:border-amber-100 focus:ring-2 focus:ring-amber-200 transition-all" />
            </div>

            <!-- Image actuelle -->
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-semibold text-dark-900 uppercase tracking-wide">Image actuelle</label>
                <div class="flex items-center gap-4 px-4 py-3 rounded-xl border border-amber-200 bg-amber-50">
                    <img src="/images/<%= stagiaire.image %>" alt="Photo actuelle"
                        class="w-12 h-12 rounded-full object-cover border-2 border-amber-300" />
                    <div>
                        <p class="text-sm text-dark-900 font-medium">Photo enregistrée</p>
                        <p class="text-xs text-dark-900 mt-0.5">Choisissez une nouvelle image pour la remplacer</p>
                    </div>
                </div>
            </div>

            <!-- Nouvelle image -->
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-semibold text-dark-900 uppercase tracking-wide">Nouvelle image</label>
                <label class="flex items-center gap-4 px-4 py-3 rounded-xl border-2 border-dashed border-amber-200 bg-amber-50 cursor-pointer hover:border-amber-400 hover:bg-amber-100 transition-all">
                    <div class="w-10 h-10 rounded-full bg-amber-100 border border-amber-200 flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 22 22">
                            <circle cx="11" cy="8" r="3.5"/>
                            <path d="M3 19c0-4 3.6-7 8-7s8 3 8 7"/>
                        </svg>
                    </div>
                    <div class="flex-1">
                        <p class="text-sm text-dark-900 font-medium">Choisir une image</p>
                        <input type="file" name="image" accept="image/*" class="hidden" />
                    </div>
                </label>
            </div>

            <!-- Boutons -->
            <div class="flex items-center justify-between pt-2">
                 <a href="/api/all"
                        class="px-5 py-2.5 rounded-xl border border-amber-200 text-amber-500 text-sm hover:bg-amber-50 hover:border-amber-300 transition-colors">
                        Annuler
                    </a>
                <div class="flex items-center gap-3">
                    <button type="submit"
                        class="px-6 py-2.5 rounded-xl bg-amber-500 hover:bg-amber-600 text-white text-sm font-medium transition-colors active:scale-95">
                        Enregistrer
                    </button>
                </div>
            </div>

        </form>
    </div>

</body>
</html>