<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ajouter un Stagiaire</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-indigo-50 min-h-screen flex items-center justify-center p-8 font-sans">

    <div class="w-full max-w-lg bg-white rounded-2xl border border-indigo-100 shadow-sm overflow-hidden">

        <!-- En-tête -->
        <div class="bg-indigo-600 px-7 py-5">
            <h2 class="text-lg font-semibold text-white">Ajouter un Stagiaire</h2>
            <p class="text-sm text-indigo-200 mt-0.5">Remplissez les informations pour créer une nouvelle fiche.</p>
        </div>

        <!-- Formulaire -->
        <form action="/api/add" method="POST" class="p-7 space-y-4" enctype="multipart/form-data">

            <!-- Numéro / nom -->
            <div class="grid grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-indigo-500 uppercase tracking-wide">
                        Numéro <span class="text-red-400">*</span>
                    </label>
                    <input type="text" name="numero" placeholder="ex. 001" 
                        class="px-3 py-2.5 rounded-xl border border-indigo-200 bg-indigo-50 text-sm text-indigo-900 placeholder-indigo-300 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all" />
                </div>
                 <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-indigo-500 uppercase tracking-wide">
                        Nom <span class="text-red-400">*</span>
                    </label>
                    <input type="text" name="nom" placeholder="ex. Benali"
                        class="px-3 py-2.5 rounded-xl border border-indigo-200 bg-indigo-50 text-sm text-indigo-900 placeholder-indigo-300 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all" />
                </div>
            </div>

            <!-- age / Prénom -->
            <div class="grid grid-cols-2 gap-4">
                <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-indigo-500 uppercase tracking-wide">
                        Prénom <span class="text-red-400">*</span>
                    </label>
                    <input type="text" name="prenom" placeholder="ex. Amine"
                        class="px-3 py-2.5 rounded-xl border border-indigo-200 bg-indigo-50 text-sm text-indigo-900 placeholder-indigo-300 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all" />
                </div>
                 <div class="flex flex-col gap-1.5">
                    <label class="text-xs font-semibold text-indigo-500 uppercase tracking-wide">
                        Âge <span class="text-red-400">*</span>
                    </label>
                    <input type="number" name="age" placeholder="ex. 22" min="1" max="120"
                        class="px-3 py-2.5 rounded-xl border border-indigo-200 bg-indigo-50 text-sm text-indigo-900 placeholder-indigo-300 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all" />
                </div>
            </div>

            <!-- Email -->
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-semibold text-indigo-500 uppercase tracking-wide">
                    Adresse e-mail <span class="text-red-400">*</span>
                </label>
                <input type="email" name="email" placeholder="exemple@domaine.com"
                    class="px-3 py-2.5 rounded-xl border border-indigo-200 bg-indigo-50 text-sm text-indigo-900 placeholder-indigo-300 focus:outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-200 transition-all" />
            </div>

            <!-- Image -->
            <div class="flex flex-col gap-1.5">
                <label class="text-xs font-semibold text-indigo-500 uppercase tracking-wide">Photo de profil</label>
                <label class="flex items-center gap-4 px-4 py-3 rounded-xl border-2 border-dashed border-indigo-200 bg-indigo-50 cursor-pointer hover:border-indigo-400 hover:bg-indigo-100 transition-all">
                    <div class="w-10 h-10 rounded-full bg-indigo-100 border border-indigo-200 flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 22 22">
                            <circle cx="11" cy="8" r="3.5"/>
                            <path d="M3 19c0-4 3.6-7 8-7s8 3 8 7"/>
                        </svg>
                    </div>
                    <div class="flex-1">
                        <p class="text-sm text-indigo-600 font-medium">Choisir une image</p>
                    </div>
                    <input type="file" name="image" class="hidden" />
                </label>
            </div>

            <!-- Boutons -->
            <div class="flex items-center justify-end gap-3 pt-2">
                <a href="/"
                    class="px-5 py-2.5 rounded-xl border border-indigo-200 text-indigo-500 text-sm hover:bg-indigo-50 hover:border-indigo-300 transition-colors">
                    Annuler
                </a>
                <button type="submit"
                    class="px-6 py-2.5 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition-colors active:scale-95">
                    Ajouter le stagiaire
                </button>
            </div>

        </form>
    </div>

</body>
</html>